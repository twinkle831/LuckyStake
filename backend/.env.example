# ─── LuckyStake Backend – Environment Variables ───────────────────────────
# Copy to .env for local dev. For Vercel/Railway, set these in project settings.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Admin Secret (required for cron jobs) ─────────────────────────────────
ADMIN_SECRET_KEY=your_super_secret_admin_key_here

# ─── Stellar Network Configuration ────────────────────────────────────────
# Options: "testnet" or "mainnet"
STELLAR_NETWORK=mainnet

# Mainnet
STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
STELLAR_RPC_URL=https://mainnet.sorobanrpc.com

# Testnet (uncomment to use testnet)
# STELLAR_NETWORK=testnet
# STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# ─── Pool Contract Addresses (mainnet) ────────────────────────────────────
POOL_CONTRACT_WEEKLY=CCEQRJQ4OLVLRRUS5SLJKGXDILYKISDV43HSBNP2QDUSIJ7ITWLHD73I
POOL_CONTRACT_BIWEEKLY=CCITIDSTLZHHGWRIAJK6JAVLMMYSJ7GUDFWOS4MNCILLZQOFWBT63DFB
POOL_CONTRACT_MONTHLY=CDAPP7TW2CU4D75KM6HL2IJPQYGDXR77O7GSIRGX7H2GNBRNY6J4LVZY

# ─── AI Agent Configuration ──────────────────────────────────────────────
# Agent API URL (FastAPI backend for conversational AI)
# Local:  http://localhost:8001
# Prod:   https://your-agent-api.railway.app
AGENT_API_URL=http://localhost:8001

# Enable/disable agent executor service (cron job)
# Set to "false" to disable automatic strategy execution
ENABLE_AGENT_EXECUTOR=true

# Cron interval for agent executor (ms) – default: 6 hours (21600000 ms)
AGENT_EXECUTOR_INTERVAL_MS=21600000

# ─── Cron Configuration ──────────────────────────────────────────────────
# Interval for draw checks and harvests (ms) – default: 1 hour
CRON_INTERVAL_MS=3600000

# ─── Database ────────────────────────────────────────────────────────────
# Data directory for JSON storage
DATA_DIR=./data

# ─── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
